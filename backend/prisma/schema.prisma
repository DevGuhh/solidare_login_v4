generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Usuario {
  id            Int                  @id @default(autoincrement())
  nome          String
  email         String               @unique
  senhaHash     String
  role          RoleUsuario          @default(INSTITUICAO)
  ativo         Boolean              @default(true)
  criadoEm      DateTime             @default(now())
  atualizadoEm  DateTime             @updatedAt
  instituicaoId Int?                 @unique
  doacoes       Doacao[]
  instituicao   InstituicaoParceira? @relation(fields: [instituicaoId], references: [id])

  @@map("usuarios")
}

model InstituicaoParceira {
  id            Int               @id @default(autoincrement())
  nome          String
  tipo          TipoInstituicao   @default(OUTRO)
  responsavel   String
  telefone      String
  endereco      String
  cidade        String
  statusOk      StatusInstituicao @default(PENDENTE)
  ativa         Boolean           @default(true)
  criadoEm      DateTime          @default(now())
  atualizadoEm  DateTime          @updatedAt
  email         String            @unique
  deletedAt     DateTime?
  beneficiarios Beneficiario[]
  doacoes       Doacao[]
  usuario       Usuario?

  @@map("instituicoes_parceiras")
}

model Beneficiario {
  id                     Int                 @id @default(autoincrement())
  nomeCompleto           String
  cpf                    String              @unique
  dataNascimento         DateTime
  logradouro             String
  numero                 String
  complemento            String?
  cep                    String?
  regiao                 String
  cidade                 String
  uf                     String
  telefonePrincipal      String
  telefoneSecundario     String?
  email                  String?
  instituicaoId          Int
  tipoBeneficio          TipoBeneficio       @default(CESTA)
  situacaoSocioeconomica String?
  dataCadastro           DateTime            @default(now())
  observacoes            String?
  ativo                  Boolean             @default(true)
  criadoEm               DateTime            @default(now())
  atualizadoEm           DateTime            @updatedAt
  deletedAt              DateTime?
  instituicao            InstituicaoParceira @relation(fields: [instituicaoId], references: [id])
  doacoes                Doacao[]

  @@index([instituicaoId])
  @@map("beneficiarios")
}

model Doacao {
  id             Int                 @id @default(autoincrement())
  codigo         String              @unique
  beneficiarioId Int
  instituicaoId  Int
  tipo           TipoBeneficio
  quantidade     Int
  observacoes    String?
  comprovante    Boolean             @default(false)
  dataDoacao     DateTime            @default(now())
  criadoEm       DateTime            @default(now())
  atualizadoEm   DateTime            @updatedAt
  deletedAt      DateTime?
  usuarioId      Int
  beneficiario   Beneficiario        @relation(fields: [beneficiarioId], references: [id])
  instituicao    InstituicaoParceira @relation(fields: [instituicaoId], references: [id])
  usuario        Usuario             @relation(fields: [usuarioId], references: [id])

  @@index([beneficiarioId])
  @@index([instituicaoId])
  @@index([usuarioId])
  @@index([dataDoacao])
  @@index([instituicaoId, dataDoacao])
  @@map("doacoes")
}

enum RoleUsuario {
  ADMIN
  INSTITUICAO
}

enum TipoInstituicao {
  IGREJA
  ASSOCIACAO
  ONG
  OUTRO
}

enum StatusInstituicao {
  OK
  PENDENTE
}

enum TipoBeneficio {
  CESTA
  GRANEL
  AMBOS
}
